---
import { navigation } from '../config/navigation';
import LanguageSwitcher from '../components/LanguageSwitcher';
import DocsNav from '../components/DocsNav.astro';

interface Props {
  title: string;
  lang: 'en' | 'zh';
  activeId: string;
}

// Access frontmatter from MDX
const { frontmatter } = Astro.props as any;
const title = frontmatter?.title || Astro.props.title;
const lang = frontmatter?.lang || Astro.props.lang || 'en';
const activeId = frontmatter?.activeId || Astro.props.activeId;
const baseUrl = import.meta.env.BASE_URL;
const localizedPath = (targetLang: 'en' | 'zh', id: string) =>
  `${baseUrl}${targetLang === 'en' ? '' : `${targetLang}/`}${id}/`;

// Create refs for use in template expressions
const navItems = navigation.map(group => ({
  title: group.title[lang],
  items: group.items.map(item => ({
    id: item.id,
    title: item.title[lang],
    icon: item.icon || '',
    isActive: item.id === activeId,
    href: localizedPath(lang, item.id)
  }))
}));

const backHomeText = lang === 'en' ? 'Back to Home' : '返回首页';
const tocTitle = lang === 'en' ? 'ON THIS PAGE' : '本页内容';
const menuText = lang === 'en' ? 'Menu' : '菜单';
const closeText = lang === 'en' ? 'Close navigation' : '关闭导航';
const langSwitchUrl = localizedPath(lang === 'en' ? 'zh' : 'en', activeId);
const editOnGitHubText = lang === 'en' ? 'Edit this page on GitHub' : '在 GitHub 上编辑此页';
const githubEditUrl = `https://github.com/leason-wan/awesome-seedance-2.0/issues`;
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID?.trim();
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION?.trim();
const gaInitScript = gaMeasurementId
  ? `window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', '${gaMeasurementId}');`
  : '';
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} | lytai API Documentation</title>
  <link rel="icon" type="image/svg+xml" href={`${baseUrl}logo.svg`}>
  {googleSiteVerification && (
    <meta name="google-site-verification" content={googleSiteVerification} />
  )}
  {gaMeasurementId && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
      <script is:inline set:html={gaInitScript}></script>
    </>
  )}
</head>
<body class="bg-[#000000] text-[#f0f6fc] overflow-x-hidden antialiased">
  <div class="min-h-screen w-full">
    <div class="lg:hidden border-b border-gray-800/80 bg-black/95 backdrop-blur supports-[backdrop-filter]:bg-black/80">
      <div class="mx-auto flex max-w-7xl items-center gap-3 px-4 py-3 sm:px-5">
        <button
          type="button"
          data-mobile-nav-toggle
          class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-gray-800 bg-gray-950 text-gray-200 transition-colors hover:border-gray-700 hover:text-white"
          aria-controls="mobile-docs-nav"
          aria-expanded="false"
          aria-label={menuText}
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7h16M4 12h16M4 17h16"></path>
          </svg>
        </button>
        <div class="min-w-0 flex-1">
          <div class="truncate text-sm font-semibold text-white">{title}</div>
          <div class="truncate text-xs uppercase tracking-[0.2em] text-gray-500">lytai docs</div>
        </div>
        <div class="w-[7.5rem] shrink-0">
          <LanguageSwitcher client:load currentLang={lang} switchUrl={langSwitchUrl} />
        </div>
      </div>
    </div>

    <div
      id="mobile-nav-backdrop"
      data-mobile-nav-backdrop
      class="pointer-events-none fixed inset-0 z-40 bg-black/70 opacity-0 transition-opacity duration-200 lg:hidden"
      aria-hidden="true"
    ></div>

    <aside
      id="mobile-docs-nav"
      data-mobile-nav-drawer
      class="fixed inset-y-0 left-0 z-50 w-[min(88vw,22rem)] -translate-x-full overflow-y-auto border-r border-gray-800 bg-black px-4 py-5 shadow-2xl transition-transform duration-200 lg:hidden"
      aria-hidden="true"
    >
      <div class="mb-4 flex items-center justify-between gap-3">
        <div>
          <div class="text-xs uppercase tracking-[0.2em] text-gray-500">{menuText}</div>
          <div class="text-sm font-semibold text-white">{title}</div>
        </div>
        <button
          type="button"
          data-mobile-nav-close
          class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-gray-800 bg-gray-950 text-gray-200 transition-colors hover:border-gray-700 hover:text-white"
          aria-label={closeText}
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
      <DocsNav
        navItems={navItems}
        backHomeText={backHomeText}
        lang={lang}
        langSwitchUrl={langSwitchUrl}
        mobile={true}
      />
    </aside>

    <div class="flex min-h-screen min-w-0">
      <!-- Left Sidebar - Navigation (Hidden on mobile) -->
      <aside class="hidden lg:block w-64 flex-shrink-0 bg-[#000000] border-r border-gray-700/50">
        <div class="sticky top-8 px-6 py-8">
          <DocsNav
            navItems={navItems}
            backHomeText={backHomeText}
            lang={lang}
            langSwitchUrl={langSwitchUrl}
          />
        </div>
      </aside>

      <!-- Main Content Area -->
      <div class="flex min-w-0 flex-1">
        <!-- Spacer for centering (hidden on mobile) -->
        <div class="hidden xl:block flex-1"></div>

        <!-- Main Content -->
        <main class="min-w-0 w-full max-w-4xl px-4 py-5 sm:px-5 sm:py-6 md:px-6 md:py-8 lg:px-8">
          <div class="mb-5 lg:hidden">
            <details class="group rounded-2xl border border-gray-800 bg-gray-950/70">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-3 px-4 py-3 text-sm font-medium text-gray-200">
                <span>{tocTitle}</span>
                <svg class="h-4 w-4 text-gray-500 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
              </summary>
              <div id="mobile-toc" class="border-t border-gray-800 px-4 py-3 text-sm space-y-2"></div>
            </details>
          </div>

          <article class="docs-content">
            <slot />
          </article>

          <!-- Edit on GitHub -->
          <div class="mt-10 border-t border-gray-700 pt-6 sm:mt-12">
            <a
              href={githubEditUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-gray-400 transition-colors hover:text-white"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
              </svg>
              {editOnGitHubText}
            </a>
          </div>
        </main>

        <!-- Spacer for centering (hidden on mobile) -->
        <div class="hidden xl:block flex-1"></div>
      </div>

      <!-- Right Sidebar - Table of Contents (Hidden on mobile and tablet) -->
      <aside class="hidden xl:block w-64 flex-shrink-0 bg-[#000000] border-l border-gray-700/50">
        <div class="sticky top-8 px-6 py-8">
          <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">
            {tocTitle}
          </h3>
          <div id="toc" class="text-sm space-y-2"></div>
        </div>
      </aside>
    </div>

    <!-- Footer -->
    <footer class="border-t border-gray-700/50 bg-[#000000]">
      <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6">
        <div class="flex flex-col items-start justify-between gap-5 md:flex-row md:items-center">
          <!-- Copyright -->
          <div class="text-sm text-gray-600">
            © 2026 lytai.studio All rights reserved.
          </div>
          <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-gray-500">
            <span>Models:</span>
            <a href="https://seed.bytedance.com/en/seedance2_0" target="_blank" rel="noopener noreferrer" class="whitespace-nowrap transition-colors hover:text-white">
              Seedance 2.0
            </a>
            <a href="https://www.deepseek.com/" target="_blank" rel="noopener noreferrer" class="whitespace-nowrap transition-colors hover:text-white">
              DeepSeek
            </a>
            <a href="https://klingai.com/" target="_blank" rel="noopener noreferrer" class="whitespace-nowrap transition-colors hover:text-white">
              Kling
            </a>
            <a href="https://deepmind.google/technologies/veo/" target="_blank" rel="noopener noreferrer" class="whitespace-nowrap transition-colors hover:text-white">
              Veo
            </a>
            <a href="https://openai.com/sora" target="_blank" rel="noopener noreferrer" class="whitespace-nowrap transition-colors hover:text-white">
              Sora
            </a>
          </div>
        </div>
      </div>
    </footer>
  </div>

  <style is:global>
    /* Smooth scroll */
    html {
      scroll-behavior: smooth;
    }

    /* Custom scrollbar */
    ::-webkit-scrollbar {
      width: 8px;
      height: 8px;
    }

    ::-webkit-scrollbar-track {
      background: #f1f1f1;
    }

    ::-webkit-scrollbar-thumb {
      background: #888;
      border-radius: 4px;
    }

    ::-webkit-scrollbar-thumb:hover {
      background: #555;
    }

    /* Docs content styling - mobile-first approach */
    html.docs-nav-open,
    body.docs-nav-open {
      overflow: hidden;
    }

    .docs-content {
      color: #e1e4e8;
      font-size: 0.975rem;
      line-height: 1.75;
      width: 100%;
      max-width: 100%;
      min-width: 0;
    }

    .docs-content > * {
      max-width: 100%;
      min-width: 0;
    }

    @media (min-width: 768px) {
      .docs-content {
        font-size: 1rem;
        line-height: 1.7;
      }
    }

    .docs-content h1 {
      font-size: clamp(1.9rem, 6vw, 2.5rem);
      font-weight: 800;
      color: #ffffff;
      margin-bottom: 1.5rem;
      margin-top: 0;
      letter-spacing: -0.02em;
      line-height: 1.15;
    }

    @media (min-width: 768px) {
      .docs-content h1 {
        font-size: 2.25rem;
      }
    }

    .docs-content h2 {
      font-size: clamp(1.35rem, 4.8vw, 1.8rem);
      font-weight: 700;
      color: #ffffff;
      margin-top: 2.5rem;
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid #3e4451;
      letter-spacing: -0.01em;
      line-height: 1.25;
    }

    @media (min-width: 768px) {
      .docs-content h2 {
        font-size: 1.5rem;
        margin-top: 2.5rem;
      }
    }

    .docs-content h3 {
      font-size: clamp(1.1rem, 4vw, 1.4rem);
      font-weight: 600;
      color: #ffffff;
      margin-top: 1.75rem;
      margin-bottom: 0.75rem;
      line-height: 1.35;
    }

    @media (min-width: 768px) {
      .docs-content h3 {
        font-size: 1.125rem;
        margin-top: 1.5rem;
      }
    }

    .docs-content p {
      margin-top: 0.875rem;
      margin-bottom: 0.875rem;
      color: #e1e4e8;
      line-height: 1.72;
    }

    .docs-content a {
      color: #4493f8;
      text-decoration: none;
      font-weight: 500;
    }

    .docs-content a:hover {
      text-decoration: underline;
    }

    .docs-content ul,
    .docs-content ol {
      margin-top: 0.875rem;
      margin-bottom: 0.875rem;
      padding-left: 1.5rem;
    }

    .docs-content ul {
      list-style-type: disc;
    }

    .docs-content ol {
      list-style-type: decimal;
    }

    .docs-content li {
      margin-top: 0.4rem;
      margin-bottom: 0.4rem;
      color: #e1e4e8;
      line-height: 1.72;
    }

    .docs-content li::marker {
      color: #adbac7;
      font-weight: 600;
    }

    .docs-content strong {
      color: #f3f4f6;
      font-weight: 600;
    }

    .docs-content :not(pre) > code {
      font-size: 0.875rem;
      background-color: #2c313a;
      color: #abb2bf;
      padding: 0.2rem 0.4rem;
      border-radius: 6px;
      font-family: ui-monospace, SFMono-Regular, SF Mono, Menlo, Consolas, Liberation Mono, monospace;
    }

    /* Style for markdown code blocks - mobile-first */
    .docs-content pre {
      background-color: #1e1e1e;
      border-radius: 0.375rem;
      padding: 1rem;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      margin: 0.875rem 0;
      font-size: 0.8125rem;
      line-height: 1.7;
      max-width: 100%;
    }

    @media (min-width: 768px) {
      .docs-content pre {
        border-radius: 0.5rem;
        padding: 1.25rem 1.5rem;
        margin: 1.5rem 0;
        font-size: 0.875rem;
      }
    }

    /* Don't style code blocks from CodeExample component */
    .docs-content .not-content pre {
      padding: 0;
      margin: 0;
      border-radius: 0;
    }

    .docs-content pre code {
      all: unset;
      display: block;
      color: #d4d4d4;
      font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
    }

    .docs-content img,
    .docs-content video,
    .docs-content svg,
    .docs-content iframe {
      display: block;
      max-width: 100%;
      height: auto;
    }

    /* Tables - mobile-first */
    .docs-content table {
      width: 100%;
      margin-top: 1.25rem;
      margin-bottom: 1.25rem;
      border-collapse: collapse;
      display: block;
      overflow-x: auto;
      white-space: nowrap;
      font-size: 0.8125rem;
    }

    @media (min-width: 768px) {
      .docs-content table {
        display: table;
        white-space: normal;
        font-size: 0.875rem;
      }
    }

    .docs-content th {
      background-color: #282c34;
      padding: 0.65rem 0.75rem;
      text-align: left;
      font-weight: 600;
      border-bottom: 2px solid #3e4451;
      color: #ffffff;
    }

    @media (min-width: 768px) {
      .docs-content th {
        padding: 0.75rem;
      }
    }

    .docs-content td {
      padding: 0.5rem 0.65rem;
      border-bottom: 1px solid #3e4451;
    }

    @media (min-width: 768px) {
      .docs-content td {
        padding: 0.75rem;
      }
    }

    .docs-content blockquote {
      border-left: 4px solid #4b5263;
      padding-left: 1rem;
      margin: 1.25rem 0;
      color: #abb2bf;
      font-size: 1rem;
    }

    /* Prevent docs-content styles from affecting CodeExample components */
    .docs-content .not-content {
      font-size: initial;
      color: initial;
      line-height: initial;
    }

    /* Ensure CodeExample components are responsive on mobile */
    .docs-content .not-content {
      max-width: 100%;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .docs-content .not-content > div {
      max-width: 100%;
    }

    /* Code blocks inside CodeExample should allow horizontal scroll */
    .docs-content .not-content pre,
    .docs-content .not-content code {
      max-width: 100%;
      white-space: pre;
      word-wrap: normal;
      overflow-wrap: normal;
    }

    /* Touch target improvements for mobile devices */
    @media (pointer: coarse) and (max-width: 768px) {
      /* Ensure minimum touch target size of 44x44px for touch devices */
      button,
      summary,
      [data-mobile-nav-toggle],
      [data-mobile-nav-close],
      aside a,
      footer a,
      #toc a,
      #mobile-toc a {
        min-height: 44px;
        display: inline-flex;
        align-items: center;
      }

      /* Improve link spacing on mobile */
      .docs-content a {
        padding: 2px 0;
        overflow-wrap: anywhere;
      }
    }
  </style>

  <script>




    // Generate table of contents
    function generateTOC() {
      const article = document.querySelector('article');
      const tocTargets = [document.getElementById('toc'), document.getElementById('mobile-toc')].filter(Boolean);

      if (!article || tocTargets.length === 0) return;

      const headings = article.querySelectorAll('h2, h3');
      const tocItems: string[] = [];

      headings.forEach((heading) => {
        const level = heading.tagName === 'H2' ? 0 : 1;
        const text = heading.textContent || '';
        const id = heading.id || text.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');

        if (!heading.id) heading.id = id;

        tocItems.push(`
          <a href="#${id}" class="block py-1 text-gray-400 hover:text-white transition-colors ${level === 1 ? 'pl-4 text-sm' : 'font-medium'}">
            ${text}
          </a>
        `);
      });

      tocTargets.forEach((target) => {
        target.innerHTML = tocItems.join('');
      });
    }

    function initMobileNav() {
      const root = document.documentElement;
      const drawer = document.querySelector('[data-mobile-nav-drawer]');
      const backdrop = document.querySelector('[data-mobile-nav-backdrop]');
      const toggle = document.querySelector('[data-mobile-nav-toggle]');
      const closeButton = document.querySelector('[data-mobile-nav-close]');

      if (!drawer || !backdrop || !toggle || !closeButton) return;

      const setOpen = (open) => {
        root.classList.toggle('docs-nav-open', open);
        drawer.classList.toggle('-translate-x-full', !open);
        drawer.setAttribute('aria-hidden', String(!open));
        backdrop.classList.toggle('pointer-events-none', !open);
        backdrop.classList.toggle('opacity-0', !open);
        toggle.setAttribute('aria-expanded', String(open));
      };

      toggle.addEventListener('click', () => setOpen(true));
      closeButton.addEventListener('click', () => setOpen(false));
      backdrop.addEventListener('click', () => setOpen(false));

      drawer.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => setOpen(false));
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          setOpen(false);
        }
      });
    }

    // Run on load
    document.addEventListener('DOMContentLoaded', () => {
      generateTOC();
      initMobileNav();
    });
  </script>
</body>
</html>
