---
import Home from "../components/Home";

const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID?.trim();
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION?.trim();
const gaInitScript = gaMeasurementId
  ? `window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', '${gaMeasurementId}');`
  : '';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Lytai Studio</title>
  {googleSiteVerification && (
    <meta name="google-site-verification" content={googleSiteVerification} />
  )}
  {gaMeasurementId && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
      <script is:inline set:html={gaInitScript}></script>
    </>
  )}
</head>
<body class="m-0 bg-black">
  <Home client:load />
</body>
</html>
