---
import LanguageSwitcher from './LanguageSwitcher';

interface NavItem {
  id: string;
  title: string;
  icon: string;
  isActive: boolean;
  href: string;
}

interface NavGroup {
  title: string;
  items: NavItem[];
}

interface Props {
  navItems: NavGroup[];
  backHomeText: string;
  lang: 'en' | 'zh';
  langSwitchUrl: string;
  mobile?: boolean;
}

const { navItems, backHomeText, lang, langSwitchUrl, mobile = false } = Astro.props;

const iconPaths: Record<string, string> = {
  rocket: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>',
  key: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path>',
  'file-text': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>',
  'message-square': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>',
  'file-code': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>',
  image: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>',
  terminal: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>',
  'alert-triangle': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>',
  code: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>',
  'help-circle': '<circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><path d="M12 17h.01"></path>',
  book: '<path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />',
  zap: '<path d="M13 10V3L4 14h7v7l9-11h-7z" />',
  layers: '<path d="M17.5 19L12 21.5L6.5 19M17.5 14L12 16.5L6.5 14M12 4L4.5 7.5L12 11L19.5 7.5L12 4Z" />',
  video: '<path d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />',
  layout: '<path d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />',
  'edit-3': '<path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />',
  'trending-up': '<path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />',
  music: '<path d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />',
  repeat: '<path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />',
  scissors: '<path d="M7 11a2 2 0 100-4 2 2 0 000 4zM17 11a2 2 0 100-4 2 2 0 000 4zM16 11l-2.001 2.001M8 11l6.5 6.5M14 13l1 1h4m-12 3h4l1-1" />',
  activity: '<path d="M22 12h-4l-3 9L9 3l-3 9H2" />',
  smile: '<path d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />'
};
---

<div class:list={['docs-nav', mobile ? 'docs-nav-mobile' : 'docs-nav-desktop']}>
  <a href="/" class="flex items-center gap-2 text-sm text-gray-400 hover:text-white mb-6 transition-colors">
    <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
    </svg>
    <span>{backHomeText}</span>
  </a>

  <nav class="space-y-4">
    {navItems.map((group) => (
      <div>
        <h3 class="mb-2 text-xs font-semibold uppercase tracking-wider text-gray-500">
          {group.title}
        </h3>
        <ul class="space-y-1">
          {group.items.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  'flex items-center gap-2 rounded-lg px-3 py-2 text-sm transition-all duration-200',
                  item.isActive
                    ? 'bg-blue-600/20 text-blue-300 font-semibold shadow-inner'
                    : 'text-gray-400 hover:bg-gray-700/40 hover:text-white'
                ]}
              >
                {item.icon && (
                  <svg
                    class="h-4 w-4 shrink-0"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    viewBox="0 0 24 24"
                    set:html={iconPaths[item.icon]}
                  />
                )}
                <span>{item.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </nav>

  <div class="mt-6 border-t border-gray-700 pt-6">
    <LanguageSwitcher client:load currentLang={lang} switchUrl={langSwitchUrl} />
  </div>
</div>
